<!DOCTYPE html>
<html lang="en">
<head>
    <title>Blog App</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="title-bar">
    <h1>Blog App</h1>
</div>

<div class="main">
    <div class="row g-0" style="height: calc(100vh - 60px);">

        <!-- New Post Form -->
        <div class="col-12 col-lg-3 form-panel">
            <h2>New Post</h2>
            <form action="/posts" method="POST" class="post-form">
                <input type="text" name="author" placeholder="Your Name" required />
                <input type="text" name="title" placeholder="Post Title" required />
                <textarea name="content" placeholder="Write your post..." required></textarea>
                <button type="submit">Add Post</button>
            </form>
        </div>

        <!-- Posts Display -->
        <div class="col-12 col-lg-9 posts-panel">
            <div class="posts-header">
                <h2>Posts</h2>
                <input type="text" id="search_bar" placeholder="Search posts..." />
            </div>

            <% if (posts.length === 0) { %>
                <p class="no-posts">No posts yet. Create one!</p>
            <% } else { %>
                <div class="card-grid" id="cardGrid">
                    <% posts.forEach(post => { %>
                        <div class="blog-card" data-text="<%= (post.title + post.author + post.content).toLowerCase() %>">
                            <button class="delete-button" onclick="submitForm('delete-<%= post.id %>')">✕</button>
                            <div class="card-body-content">
                                <h3><%= post.title %></h3>
                                <p class="author">By <%= post.author %></p>
                                <div class="post-content"><%= post.content %></div>
                                <p class="timestamp"><%= post.createdAt %></p>
                            </div>
                            <div class="card-actions">
                                <a href="/posts/<%= post.id %>/edit" class="edit-btn">Edit</a>
                            </div>
                            <form id="delete-<%= post.id %>" action="/posts/<%= post.id %>/delete" method="POST" style="display:none;"></form>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

    </div>
</div>

<div class="footer">
    <p>© Blog App</p>
</div>

<script>
function submitForm(id) {
    document.getElementById(id).submit();
}

document.getElementById('search_bar').addEventListener('input', function () {
    const query = this.value.toLowerCase();
    document.querySelectorAll('.blog-card').forEach(card => {
        card.style.display = card.dataset.text.includes(query) ? 'flex' : 'none';
    });
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
